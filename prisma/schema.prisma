// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model for authentication and user management
model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  phone         String?
  company       String?
  position      String?
  role          UserRole     @default(STUDENT)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  enrollments   Enrollment[]
  bookings      Booking[]
  leads         Lead[]
  
  @@index([email])
}

enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
}

// Course model for petroleum and gas training courses
model Course {
  id              String         @id @default(cuid())
  slug            String         @unique
  title           String
  description     String         @db.Text
  category        Category
  subCategory     UpstreamSubCategory? //  NEW (nullable)
  duration        String         // e.g., "8 weeks", "3 months"
  level           Level
  price           Decimal        @db.Decimal(10, 2)
  currency        String         @default("USD")
  thumbnail       String?
  instructor      String
  rating          Decimal        @db.Decimal(3, 2) @default(0)
  studentsEnrolled Int           @default(0)
  objectives      String[]       // Array of learning objectives
  prerequisites   String[]       // Array of prerequisites
  certifications  String[]       // Array of certifications offered
  deliveryMode    DeliveryMode
  nextStartDate   DateTime?
  featured        Boolean        @default(false)
  published       Boolean        @default(false)
  modules         Json?          // Store course modules as JSON
  content         Json?          // Additional content data
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  enrollments     Enrollment[]
  
  @@index([slug])
  @@index([category])
  @@index([level])
  @@index([featured])
  @@index([published])
}

enum Category {
  UPSTREAM
  MIDSTREAM
  DOWNSTREAM
  SAFETY
  MANAGEMENT
  TECHNICAL
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum DeliveryMode {
  ONLINE
  IN_PERSON
  HYBRID
}

// Enrollment model for course registrations
model Enrollment {
  id              String           @id @default(cuid())
  userId          String
  courseId        String
  fullName        String
  email           String
  phone           String
  company         String?
  position        String?
  experience      String           // Years of experience
  startDate       DateTime
  status          EnrollmentStatus @default(PENDING)
  paymentStatus   PaymentStatus    @default(PENDING)
  message         String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@index([email])
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// Booking model for consulting services
model Booking {
  id              String        @id @default(cuid())
  userId          String?
  serviceName     String
  fullName        String
  email           String
  phone           String
  company         String
  preferredDate   DateTime
  status          BookingStatus @default(PENDING)
  message         String?       @db.Text
  notes           String?       @db.Text // Internal notes
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([status])
  @@index([email])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

// Lead model for lead capture forms
model Lead {
  id              String      @id @default(cuid())
  userId          String?
  fullName        String
  email           String
  phone           String
  interest        String      // Area of interest
  company         String?
  source          String?     // Lead source (website, referral, etc.)
  status          LeadStatus  @default(NEW)
  notes           String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([status])
  @@index([email])
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

// Instructor model for course instructors
model Instructor {
  id              String   @id @default(cuid())
  name            String
  title           String
  bio             String   @db.Text
  expertise       String[] // Areas of expertise
  photo           String?
  email           String   @unique
  phone           String?
  linkedIn        String?
  yearsExperience Int
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([email])
}

// Newsletter subscription model
model Newsletter {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  subscribed      Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([email])
}

// Contact form submissions
model Contact {
  id              String        @id @default(cuid())
  name            String
  email           String
  phone           String?
  subject         String
  message         String        @db.Text
  status          ContactStatus @default(NEW)
  replied         Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([status])
  @@index([email])
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// Testimonials/Reviews
model Testimonial {
  id              String   @id @default(cuid())
  name            String
  position        String?
  company         String?
  courseId        String?
  rating          Int      // 1-5 rating
  content         String   @db.Text
  photo           String?
  approved        Boolean  @default(false)
  featured        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([approved])
  @@index([featured])
}